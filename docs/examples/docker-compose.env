# docker-compose overrides for local quickstart
PORT=8080
LOG_LEVEL=info
PGDATABASE=kubeop
PGUSER=postgres
PGPASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://postgres:postgres@postgres:5432/kubeop?sslmode=disable
ADMIN_JWT_SECRET=dev-admin-secret-change-me
KCFG_ENCRYPTION_KEY=dev-not-secure-key
EVENTS_DB_ENABLED=true
EVENT_BRIDGE_ENABLED=false
