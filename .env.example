# -----------------------------------------------------------------------------
# kubeOP Environment Configuration Sample (.env.example)
# -----------------------------------------------------------------------------
# Copy this file to `.env` and tweak the values for your environment. Docker
# Compose consumes `.env` automatically, and the kubeOP binary also honours the
# same variables. Provide secrets through GitHub Actions or your secrets store.

# -----------------------------------------------------------------------------
# Runtime basics
# -----------------------------------------------------------------------------
# APP_ENV controls high level behaviour switches (development|staging|production)
APP_ENV=development

# PORT is the HTTP listener port for the API service. Example: 8080
PORT=8080

# KUBEOP_BASE_URL is the externally reachable URL for the API (handshake + ingest).
# Example: https://kubeop.example.com
KUBEOP_BASE_URL=

# ALLOW_INSECURE_HTTP permits http:// base URLs (development only). Leave false in production.
ALLOW_INSECURE_HTTP=false

# LOG_LEVEL adjusts verbosity (debug|info|warn|error). Example: info
LOG_LEVEL=info

# LOGS_ROOT is where logs and rotated files land when running via Docker.
# Example: /var/log/kubeop
LOGS_ROOT=/var/log/kubeop

# LOG_DIR is the legacy path used by pre-0.8.0 deployments. Leave aligned with
# LOGS_ROOT unless you have specific rotation needs.
LOG_DIR=/var/log/kubeop

# Lumberjack rotation knobs (sizes in MiB, age in days)
LOG_MAX_SIZE_MB=50
LOG_MAX_BACKUPS=7
LOG_MAX_AGE_DAYS=14
LOG_COMPRESS=true

# AUDIT_ENABLED enables audit log emission. Example: true
AUDIT_ENABLED=true

# DISABLE_AUTH should only be true in development sandboxes.
DISABLE_AUTH=false

# ADMIN_JWT_SECRET secures admin endpoints. Provide a strong 32+ char secret.
ADMIN_JWT_SECRET=change-me-please

# KCFG_ENCRYPTION_KEY protects kubeconfig payloads at rest. 32 bytes suggested.
KCFG_ENCRYPTION_KEY=change-me-too

# Optional path to a YAML config file that overrides environment defaults.
# Example: CONFIG_FILE=./config.yaml
# CONFIG_FILE=

# -----------------------------------------------------------------------------
# Database connectivity
# -----------------------------------------------------------------------------
# Compose defaults for the bundled PostgreSQL container. Override to use an
# existing database server. Example: kubeop
PGDATABASE=kubeop

# Database authentication credentials. Example password shown for local use.
PGUSER=postgres
PGPASSWORD=postgres

# Container bootstrap variables for the local postgres service. These mirror
# the PG* values but use the keys expected by the upstream image.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kubeop

# Host/port the API should use when connecting to Postgres. The default host is
# the Compose service name. Example: postgres
PGHOST=postgres
POSTGRES_PORT=5432

# DATABASE_URL takes precedence over the PG* variables. When using the bundled
# Compose stack keep the host as `postgres` so both services share the network.
# Example: postgres://postgres:postgres@postgres:5432/kubeop?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@postgres:5432/kubeop?sslmode=disable

# EVENTS_DB_ENABLED toggles optional event storage for audit webhooks.
EVENTS_DB_ENABLED=true

# K8S_EVENTS_BRIDGE enables forwarding Kubernetes events into kubeOP.
K8S_EVENTS_BRIDGE=false

# -----------------------------------------------------------------------------
# Tenancy / Isolation defaults
# -----------------------------------------------------------------------------
POD_SECURITY_LEVEL=baseline
POD_SECURITY_WARN_LEVEL=
POD_SECURITY_AUDIT_LEVEL=
DNS_NS_LABEL_KEY=kubernetes.io/metadata.name
DNS_NS_LABEL_VALUE=kube-system
DNS_POD_LABEL_KEY=k8s-app
DNS_POD_LABEL_VALUE=kube-dns
INGRESS_NS_LABEL_KEY=kubeop.io/ingress
INGRESS_NS_LABEL_VALUE=true

# -----------------------------------------------------------------------------
# Namespace limit policy (ResourceQuota + LimitRange)
# -----------------------------------------------------------------------------
# These values seed the NamespaceLimitPolicy applied to every managed namespace.
# Adjust them to shape tenant quotas and per-container defaults. ResourceQuota
# keys cap total namespace usage; LimitRange keys define per-container and
# per-pod min/max/defaults (including extended resources like GPUs).
KUBEOP_DEFAULT_REQUESTS_CPU=2
KUBEOP_DEFAULT_LIMITS_CPU=4
KUBEOP_DEFAULT_REQUESTS_MEMORY=4Gi
KUBEOP_DEFAULT_LIMITS_MEMORY=8Gi
KUBEOP_DEFAULT_REQUESTS_EPHEMERAL=10Gi
KUBEOP_DEFAULT_LIMITS_EPHEMERAL=20Gi
KUBEOP_DEFAULT_PODS=30
KUBEOP_DEFAULT_SERVICES=10
KUBEOP_DEFAULT_SERVICES_LOADBALANCERS=1
KUBEOP_DEFAULT_CONFIGMAPS=100
KUBEOP_DEFAULT_SECRETS=100
KUBEOP_DEFAULT_PVCS=10
KUBEOP_DEFAULT_REQUESTS_STORAGE=200Gi
KUBEOP_DEFAULT_DEPLOYMENTS_APPS=20
KUBEOP_DEFAULT_REPLICASETS_APPS=40
KUBEOP_DEFAULT_STATEFULSETS_APPS=5
KUBEOP_DEFAULT_JOBS_BATCH=20
KUBEOP_DEFAULT_CRONJOBS_BATCH=10
KUBEOP_DEFAULT_INGRESSES_NETWORKING_K8S_IO=10
KUBEOP_DEFAULT_SCOPES=NotBestEffort
KUBEOP_DEFAULT_PRIORITY_CLASSES=

# LimitRange container defaults (per container)
KUBEOP_DEFAULT_LR_CONTAINER_MAX_CPU=2
KUBEOP_DEFAULT_LR_CONTAINER_MAX_MEMORY=2Gi
KUBEOP_DEFAULT_LR_CONTAINER_MIN_CPU=100m
KUBEOP_DEFAULT_LR_CONTAINER_MIN_MEMORY=128Mi
KUBEOP_DEFAULT_LR_CONTAINER_DEFAULT_CPU=500m
KUBEOP_DEFAULT_LR_CONTAINER_DEFAULT_MEMORY=512Mi
KUBEOP_DEFAULT_LR_CONTAINER_DEFAULTREQUEST_CPU=300m
KUBEOP_DEFAULT_LR_CONTAINER_DEFAULTREQUEST_MEMORY=256Mi
KUBEOP_DEFAULT_LR_CONTAINER_MAX_EPHEMERAL=2Gi
KUBEOP_DEFAULT_LR_CONTAINER_MIN_EPHEMERAL=128Mi
KUBEOP_DEFAULT_LR_CONTAINER_DEFAULT_EPHEMERAL=512Mi
KUBEOP_DEFAULT_LR_CONTAINER_DEFAULTREQUEST_EPHEMERAL=256Mi

# Extended resource limits (comma separated key=value pairs)
# Example: KUBEOP_DEFAULT_LR_EXT_MAX="example.com/device=1"
KUBEOP_DEFAULT_LR_EXT_MAX=
KUBEOP_DEFAULT_LR_EXT_MIN=
KUBEOP_DEFAULT_LR_EXT_DEFAULT=
KUBEOP_DEFAULT_LR_EXT_DEFAULTREQUEST=

# -----------------------------------------------------------------------------
# Project placement defaults
# -----------------------------------------------------------------------------
PROJECTS_IN_USER_NAMESPACE=true

# Per-project LimitRange defaults (should be <= namespace defaults; defaults shown)
PROJECT_LR_REQUEST_CPU=50m
PROJECT_LR_REQUEST_MEMORY=64Mi
PROJECT_LR_LIMIT_CPU=500m
PROJECT_LR_LIMIT_MEMORY=512Mi

# -----------------------------------------------------------------------------
# Scheduler & health checks
# -----------------------------------------------------------------------------
CLUSTER_HEALTH_INTERVAL_SECONDS=60

# -----------------------------------------------------------------------------
# Ingress & Load Balancers
# -----------------------------------------------------------------------------
# PAAS_DOMAIN is the shared domain for project routes. Example: example.com
PAAS_DOMAIN=

# Toggle wildcard DNS provisioning when using ExternalDNS integrations.
PAAS_WILDCARD_ENABLED=false

# Load balancer settings (metallb|cilium|fake). Example: metallb
LB_DRIVER=metallb
LB_METALLB_POOL=
MAX_LOADBALANCERS_PER_PROJECT=1

# -----------------------------------------------------------------------------
# Watcher auto-deployment (API server)
# -----------------------------------------------------------------------------
# WATCHER_AUTO_DEPLOY empty -> kubeOP deploys watcher when KUBEOP_BASE_URL is set.
WATCHER_AUTO_DEPLOY=

# Override when the watcher cluster exposes a webhook relay. Derived from
# KUBEOP_BASE_URL when unset. Example: WATCHER_EVENTS_URL=https://watcher.kubeop.example.com/events
WATCHER_EVENTS_URL=

WATCHER_NAMESPACE=kubeop-system
WATCHER_NAMESPACE_CREATE=true
WATCHER_WAIT_FOR_READY=true
WATCHER_READY_TIMEOUT_SECONDS=180

# -----------------------------------------------------------------------------
# Watcher bridge runtime overrides (optional)
# -----------------------------------------------------------------------------
WATCHER_IMAGE=ghcr.io/vaheed/kubeop-watcher:latest
WATCHER_BATCH_MAX=200
WATCHER_BATCH_WINDOW_MS=1000
WATCHER_STORE_PATH=/var/lib/kubeop-watcher/state.db
WATCHER_HEARTBEAT_MINUTES=5
WATCH_NAMESPACE_PREFIXES=user-

# -----------------------------------------------------------------------------
# CI Webhooks
# -----------------------------------------------------------------------------
GIT_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# External DNS automation (optional)
# -----------------------------------------------------------------------------
# DNS_PROVIDER selects http|cloudflare|powerdns. Leave blank to disable automation.
DNS_PROVIDER=

# HTTP provider credentials
DNS_API_URL=
DNS_API_KEY=
DNS_RECORD_TTL=300

# Cloudflare credentials (falls back to DNS_API_KEY when CLOUDFLARE_API_TOKEN is empty)
CLOUDFLARE_API_BASE=https://api.cloudflare.com/client/v4
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# PowerDNS credentials (PDNS_ZONE defaults to PAAS_DOMAIN when empty)
PDNS_API_URL=
PDNS_API_KEY=
PDNS_SERVER_ID=localhost
PDNS_ZONE=
