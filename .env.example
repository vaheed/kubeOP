# Application
APP_ENV=development
PORT=8080
LOG_LEVEL=info
LOG_DIR=/var/log/kubeop
LOG_MAX_SIZE_MB=50
LOG_MAX_BACKUPS=7
LOG_MAX_AGE_DAYS=14
LOG_COMPRESS=true
AUDIT_ENABLED=true
DISABLE_AUTH=false

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kubeop?sslmode=disable

# Security
ADMIN_JWT_SECRET=change-me-please
KCFG_ENCRYPTION_KEY=change-me-too

# Optional: path to config yaml
# CONFIG_FILE=./config.yaml

# Tenancy / Isolation Defaults
POD_SECURITY_LEVEL=baseline
DNS_NS_LABEL_KEY=kubernetes.io/metadata.name
DNS_NS_LABEL_VALUE=kube-system
DNS_POD_LABEL_KEY=k8s-app
DNS_POD_LABEL_VALUE=kube-dns
INGRESS_NS_LABEL_KEY=kubeop.io/ingress
INGRESS_NS_LABEL_VALUE=true
SA_TOKEN_TTL_SECONDS=3600

# Quotas and Limits defaults
DEFAULT_QUOTA_LIMITS_MEMORY=64Gi
DEFAULT_QUOTA_LIMITS_CPU=128
DEFAULT_QUOTA_EPHEMERAL_STORAGE=64Gi
DEFAULT_QUOTA_PVC_STORAGE=500Gi
DEFAULT_QUOTA_MAX_PODS=50
DEFAULT_LR_REQUEST_CPU=100m
DEFAULT_LR_REQUEST_MEMORY=128Mi
DEFAULT_LR_LIMIT_CPU=1
DEFAULT_LR_LIMIT_MEMORY=1Gi

# Project placement
PROJECTS_IN_USER_NAMESPACE=true

# Per-project LimitRange defaults (should be <= namespace defaults)
PROJECT_LR_REQUEST_CPU=50m
PROJECT_LR_REQUEST_MEMORY=64Mi
PROJECT_LR_LIMIT_CPU=500m
PROJECT_LR_LIMIT_MEMORY=512Mi

# Scheduler
CLUSTER_HEALTH_INTERVAL_SECONDS=60

# Ingress & Load Balancers (ENV-first)
PAAS_DOMAIN=
PAAS_WILDCARD_ENABLED=false
LB_DRIVER=metallb
LB_METALLB_POOL=
MAX_LOADBALANCERS_PER_PROJECT=1

# CI Webhooks (optional)
GIT_WEBHOOK_SECRET=

# External DNS automation (optional)
EXTERNAL_DNS_PROVIDER=           # cloudflare|powerdns|empty
EXTERNAL_DNS_TTL=300
# Cloudflare
CF_API_TOKEN=
CF_ZONE_ID=
# PowerDNS
PDNS_API_URL=
PDNS_API_KEY=
PDNS_SERVER_ID=localhost
PDNS_ZONE=                       # defaults to PAAS_DOMAIN if empty
