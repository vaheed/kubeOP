# Global environment defaults for kubeOP samples
# Source this file before loading sample-specific `.env` files.
# The values can be overridden by exporting variables or by defining
# them in a sample `.env` file that runs after this script.

export KUBEOP_BASE_URL="${KUBEOP_BASE_URL:-http://localhost:8080}"
export SAMPLES_LOG_ROOT="${SAMPLES_LOG_ROOT:-./logs}"
export SAMPLES_DATA_DIR="${SAMPLES_DATA_DIR:-./samples/.data}"
