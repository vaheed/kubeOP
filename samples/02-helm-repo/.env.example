# Copy to .env and populate with your environment-specific settings.
# Values defined here provide safe defaults for DRY_RUN previews.

# Required: admin token authorised to deploy apps.
AUTH_TOKEN="replace-with-admin-token"

# Required: target project identifier returned by /v1/projects.
PROJECT_ID="proj-123456"

# Required: name to assign to the Helm-backed app.
APP_NAME="helm-nginx"

# Required: URL to the Helm chart archive (.tgz). Hosted charts must use
# HTTPS port 443 and resolve to allowed addresses.
HELM_CHART_URL="https://helm.nginx.com/stable/nginx-ingress-1.6.4.tgz"

# Service exposure details rendered into the chart values.
CONTAINER_PORT=80
SERVICE_PORT=80
SERVICE_TYPE="ClusterIP"

# Optional: JSON object merged into helm.values.
# Provide an empty object if no overrides are required.
HELM_VALUES_JSON='{"service":{"type":"ClusterIP"}}'

# Optional: set to 0 to execute curl.sh/cleanup.sh against the API.
# Defaults to 1 (log-only) when unset.
DRY_RUN=1
