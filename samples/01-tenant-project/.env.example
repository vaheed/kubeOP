# Tenant and project onboarding sample configuration
# Copy to .env and update values before running the scripts.

# Admin API token with {"role":"admin"}
AUTH_TOKEN=replace-me

# Tenant identity
TENANT_EMAIL=alice@example.com
TENANT_NAME=Alice Example

# Project metadata
PROJECT_NAME=sample-apps

# Target cluster identifier returned by /v1/clusters
CLUSTER_ID=clu-12345

# Optional: set to 0 to execute curl commands instead of logging them
DRY_RUN=1
